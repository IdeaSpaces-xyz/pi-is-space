{
  "name": "@ideaspaces/pi-is-space",
  "version": "0.1.0",
  "type": "module",
  "description": "Pi extension for IdeaSpaces — local-first CLI-backed tools and skills",
  "keywords": [
    "pi-package",
    "ideaspaces",
    "agent-skills"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "build:reference": "node reference.mjs",
    "lint:skills": "node scripts/lint-skills.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ideaspaces/cli": "git+https://github.com/IdeaSpaces-xyz/cli.git#a4f80379667eeca165c2965c8e58c234a25880cc",
    "@ideaspaces/sdk": "github:IdeaSpaces-xyz/sdk#56f8880581423982faa1680de11a5478906aee01"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.8.3"
  }
}
