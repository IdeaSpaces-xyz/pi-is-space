{
  "name": "@ideaspaces/pi-is-space",
  "version": "0.1.0",
  "type": "module",
  "description": "Pi extension for IdeaSpaces — local-first CLI-backed tools and skills",
  "keywords": [
    "pi-package",
    "ideaspaces",
    "agent-skills"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "build:reference": "node reference.mjs",
    "lint:skills": "node scripts/lint-skills.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ideaspaces/cli": "git+https://github.com/IdeaSpaces-xyz/cli.git#af54bc7a7acbfd9f3d31768f3ff21e27e221efc3",
    "@ideaspaces/sdk": "github:IdeaSpaces-xyz/sdk#7a2593ca32a61980aa1a3fc38a674ef5dcfb2060"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.8.3"
  }
}
